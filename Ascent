      <div class="climb-item">
        <span class="grade-badge ${ri?.cls||''}">${c.grade}</span>
        <span style="flex:1">${sl} · ${ri?.label||c.result}<span class="zone-badge">${zoneLabel}</span></span>
      </div>
    </div>
  </div>`;
}

function closeSwipe() {
  if (swipeEl) { swipeEl.classList.remove('open'); swipeEl.style.transform = ''; }
  swipeEl = null; swipeOpen = null; swipeOffset = 0;
}

document.addEventListener('touchstart', function(e) {
  const fg = e.target.closest('.swipe-fg');
  if (!fg) { closeSwipe(); return; }
  // Close previous
  if (swipeEl && swipeEl !== fg) closeSwipe();
  swipeEl = fg;
  swipeStartX = e.touches[0].clientX;
  swipeStartY = e.touches[0].clientY;
  swipeOffset = fg.classList.contains('open') ? -72 : 0;
}, {passive:true});

document.addEventListener('touchmove', function(e) {
  if (!swipeEl) return;
  const dx = e.touches[0].clientX - swipeStartX;
  const dy = Math.abs(e.touches[0].clientY - swipeStartY);
  // Only horizontal swipes
  if (Math.abs(dx) > 8 && dy < Math.abs(dx) * 0.8) {
    const tx = Math.min(0, Math.max(-72, swipeOffset + dx));
    swipeEl.style.transform = `translateX(${tx}px)`;
  }
}, {passive:true});

document.addEventListener('touchend', function() {
  if (!swipeEl) return;
  const tx = parseFloat(swipeEl.style.transform.replace('translateX(','').replace('px)','')) || 0;
  if (tx < -30) {
    swipeEl.style.transform = 'translateX(-72px)';
    swipeEl.classList.add('open');
  } else {
    swipeEl.style.transform = '';
    swipeEl.classList.remove('open');
    swipeEl = null;
  }
});
function saveClimb() {
  if (!selGrade || !selStyle || !selResult) return;
  const dateVal = document.getElementById('logDate').value;
  const durVal = parseInt(document.getElementById('logDuration').value) || 0;
  const ts = dateVal ? new Date(dateVal+'T12:00:00').toISOString() : new Date().toISOString();
