function renderCountGoal(div, goal, climbs) {
  const now = new Date();
  const monthStart = new Date(now.getFullYear(), now.getMonth(), 1);
  const monthClimbs = climbs.filter(c => new Date(c.date) >= monthStart);
  const done = monthClimbs.length;
  const pct = Math.min(100, Math.round(done / goal.target * 100));

  // Days remaining
  const lastDay = new Date(now.getFullYear(), now.getMonth()+1, 0).getDate();
  const today = now.getDate();
  const daysRemain = lastDay - today;
  const needPerDay = daysRemain > 0 ? Math.ceil((goal.target - done) / daysRemain) : 0;

  // Big progress number
  let html = `<div class="big-progress">
    <span class="done">${done}</span><span class="sep">/</span><span class="target">${goal.target}</span><span class="unit">次</span>
  </div>`;

  // Progress bar
  html += `<div class="goal-bar"><div class="fill" style="width:${pct}%"></div></div>`;

  // Status text
  if (done >= goal.target) {
    html += '<div class="text-sm text-center mt-8" style="color:var(--green)">🎉 已达成目标！</div>';
  } else {
    html += '<div class="text-sm text-center mt-8">' +
      '还差 <b style="color:var(--accent)">' + (goal.target - done) + '</b> 次，' +
      '本月剩 <b>' + daysRemain + '</b> 天' +
      (needPerDay > 0 ? '，日均需训练 <b style="color:var(--text2)">' + needPerDay + '</b> 次' : '') +
    '</div>';
  }

  div.innerHTML = html;
}

// 训练日历（训练建议 + 自选日期日历）
function renderTrainingCalendar() {
  var div = document.getElementById('trainingCalendarContent');
  if (!div) return;
  var now = new Date();
  var goal = getGoal();
  var climbs = getClimbs();
  var html = '';

  // ── 智能训练建议（仅次数目标且未达成时显示）──
  if (goal && goal.type === 'count') {
    var monthStart = new Date(now.getFullYear(), now.getMonth(), 1);
    var monthClimbs = climbs.filter(function(c) { return new Date(c.date) >= monthStart; });
    var done = monthClimbs.length;
    var lastDay = new Date(now.getFullYear(), now.getMonth()+1, 0).getDate();
    var todayInt = now.getDate();
    var daysRemain = lastDay - todayInt;
    var remaining = goal.target - done;

    if (remaining > 0 && daysRemain > 0) {
      // Build climbByDay
      var climbByDay = {};
      monthClimbs.forEach(function(c) {
        var d = new Date(c.date).getDate();
        climbByDay[d] = (climbByDay[d]||0) + 1;
      });

      var weeksRemain = Math.max(0.5, daysRemain / 7);
      var perWeek = remaining / weeksRemain;

      // 分析用户历史训练日偏好
      var wdCounts = [0,0,0,0,0,0,0];
      monthClimbs.forEach(function(c) {
        var d = new Date(c.date);
        var wd = d.getDay();
        if (climbByDay[d.getDate()]) wdCounts[wd]++;
      });

      var ranked = [0,1,2,3,4,5,6].sort(function(a,b){ return wdCounts[b]-wdCounts[a]; });

      var targetDaysPerWeek, intensityHint;
      if (perWeek <= 1) { targetDaysPerWeek = 1; intensityHint = '保持每周 1 次即可达标'; }
      else if (perWeek <= 2) { targetDaysPerWeek = 2; intensityHint = '每周 2 次，轻松完成'; }
      else if (perWeek <= 3) { targetDaysPerWeek = 3; intensityHint = '每周 3 次，节奏刚好'; }
      else if (perWeek <= 4) { targetDaysPerWeek = 4; intensityHint = '每周 4 次，需要坚持'; }
      else if (perWeek <= 5) { targetDaysPerWeek = 5; intensityHint = '⚠ 每周需 5 次，强度偏高'; }
      else { targetDaysPerWeek = 6; intensityHint = '⚠ 目标可能过高，建议调整'; }

      // 选训练日（保证间隔）
      var allWeekdays = [0,1,2,3,4,5,6];
      var pickOrder = ranked.slice();
      allWeekdays.forEach(function(w) { if (pickOrder.indexOf(w) === -1) pickOrder.push(w); });

      var chosen = [];
      for (var wi = 0; wi < pickOrder.length; wi++) {
        if (chosen.length >= targetDaysPerWeek) break;
        var w = pickOrder[wi];
        var tooClose = chosen.some(function(c) {
          var dist = Math.min(Math.abs(w - c), 7 - Math.abs(w - c));
          return dist < 2;
        });
        if (!tooClose) chosen.push(w);
      }
      if (chosen.length < targetDaysPerWeek) {
        for (var wi2 = 0; wi2 < pickOrder.length; wi2++) {
          if (chosen.length >= targetDaysPerWeek) break;
          var w2 = pickOrder[wi2];
          if (chosen.indexOf(w2) === -1) chosen.push(w2);
        }
      }
      chosen.sort(function(a,b){ return a-b; });

      var wdLabels = ['日','一','二','三','四','五','六'];
      var weekPlan = chosen.map(function(w) { return '周' + wdLabels[w]; }).join('、');

      html += '<div style="padding:10px 12px;background:var(--bg);border-radius:8px;margin-bottom:12px">';
      html += '<div style="font-size:12px;color:var(--text2);margin-bottom:4px">💡 智能训练建议</div>';
      html += '<div style="font-size:14px;font-weight:700;margin-bottom:2px">'+weekPlan+'</div>';
      html += '<div style="font-size:12px;color:var(--text2)">'+intensityHint+'</div>';
      html += '</div>';
    }
  }

  // ── 自选训练日期日历 ──
  var trainDates = getTrainDates();
  var firstDayOfWeekT = new Date(now.getFullYear(), now.getMonth(), 1).getDay();
  var htmlLastDay = new Date(now.getFullYear(), now.getMonth()+1, 0).getDate();
  var todayStr = now.getDate();
  var highlighted = 0;

  html += '<div style="font-size:11px;color:var(--text2);margin-bottom:6px">点击日期添加/取消训练日</div>';
  var calHtml = '<div class="cal-grid">';
  ['日','一','二','三','四','五','六'].forEach(function(h) { calHtml += '<div class="day-head">'+h+'</div>'; });
  for (var i = 0; i < firstDayOfWeekT; i++) { calHtml += '<div></div>'; }
  for (var d = 1; d <= htmlLastDay; d++) {
    var ds = now.getFullYear()+'-'+String(now.getMonth()+1).padStart(2,'0')+'-'+String(d).padStart(2,'0');
    var isTrain = trainDates.indexOf(ds) !== -1;
    if (isTrain) highlighted++;
    var isPast = d < todayStr;
    var style = '';
    if (isTrain) {
      style = 'background:var(--accent);color:#fff;cursor:pointer';
    } else if (isPast) {
      style = 'color:#555;cursor:pointer';
    } else {
      style = 'cursor:pointer;color:var(--text)';
    }
    calHtml += '<div class="day" style="'+style+'" onclick="toggleTrainDate(\''+ds+'\')">'+d+'</div>';
  }
  calHtml += '</div>';
  html += calHtml;

  if (highlighted > 0) {
    html += '<div style="font-size:11px;color:var(--text2);margin-top:4px">本月已设置 <b style="color:var(--accent)">'+highlighted+'</b> 个训练日</div>';
  }

  div.innerHTML = html;
}

function renderGradeGoal(div, goal, climbs) {
  const now = new Date();
  const monthStart = new Date(now.getFullYear(), now.getMonth(), 1);

  // Sends at target grade or above this month (sends only)
  const monthSends = climbs.filter(c =>
    new Date(c.date) >= monthStart && c.result !== 'project' && GRADES.indexOf(c.grade) >= GRADES.indexOf(goal.target)
  );

  // All attempts at target grade+ this month
  const monthAttempts = climbs.filter(c =>
    new Date(c.date) >= monthStart && GRADES.indexOf(c.grade) >= GRADES.indexOf(goal.target)
  );

  const done = monthSends.length > 0;

  let html = `<div class="big-progress">
    <span class="done" style="color:${done?'var(--green)':'var(--accent)'}">${goal.target}</span>
    <span class="unit" style="font-size:16px">及以上</span>
  </div>`;

  // Attempt stats
  html += `<div style="display:flex;gap:16px;justify-content:center;font-size:14px;margin-bottom:8px">`;
  html += `<span>尝试 <b>${monthAttempts.length}</b> 条</span>`;
  html += `<span>完攀 <b style="color:var(--green)">${monthSends.length}</b> 条</span>`;
  html += `<span>成功率 <b>${monthAttempts.length>0?Math.round(monthSends.length/monthAttempts.length*100):0}%</b></span>`;
  html += `</div>`;

  // Status
  if (done) {
    html += '<div class="text-sm text-center mt-8" style="color:var(--green)">✅ 已达成！本月完成了 ' + monthSends.length + ' 条 ' + goal.target + ' 及以上难度的线路</div>';
  } else if (monthAttempts.length > 0) {
    html += '<div class="text-sm text-center mt-8" style="color:var(--text2)">尚未达成，但已在尝试中。坚持！</div>';
  } else {
    html += '<div class="text-sm text-center mt-8" style="color:var(--text2)">本月还没有 ' + goal.target + ' 及以上的记录，加油！</div>';
  }

  // List recent attempts at this grade
  const recentAttempts = monthAttempts.sort((a,b)=>new Date(b.date)-new Date(a.date)).slice(0, 10);
  if (recentAttempts.length > 0) {
    html += '<div class="text-sm mt-16 mb-8" style="color:var(--text2)">本月记录</div>';
    recentAttempts.forEach(c => {
      const styles = ZONE_STYLES[c.zone]||ZONE_STYLES.boulder;
      const sl = styles.find(s=>s.key===c.style)?.label||c.style;
      const ri = RESULTS.find(r=>r.key===c.result);
      const zl = c.zone==='rope'?'绳攀':'抱石';
      const d = new Date(c.date).toLocaleDateString('zh-CN',{month:'numeric',day:'numeric'});
      html += `<div class="climb-item">
        <span class="grade-badge ${ri?.cls||''}">${c.grade}</span>
        <span style="flex:1;font-size:14px">${sl} · ${ri?.label||c.result}<span class="zone-badge">${zl}</span></span>
        <span style="font-size:12px;color:var(--text2)">${d}</span>
      </div>`;
    });
  }

  div.innerHTML = html;
}

// 目标攻克难度
function renderTarget() {
  const target = getTarget();
  const div = document.getElementById('targetContent');
  if (!target) {
    div.innerHTML = '<div style="text-align:center;padding:16px;color:var(--text2)">尚未设置目标攻克难度</div>';
    return;
  }
  const climbs = getClimbs();
  const targetClimbs = climbs.filter(c => c.grade === target.grade);
  const sends = targetClimbs.filter(c => c.result !== 'project');

  div.innerHTML = `
    <div class="big-grade">${target.grade}</div>
    <div style="display:flex;gap:16px;justify-content:center;font-size:14px">
      <div style="text-align:center"><b style="font-size:22px">${targetClimbs.length}</b><br><span class="text-sm">总尝试</span></div>
      <div style="text-align:center"><b style="font-size:22px;color:var(--green)">${sends.length}</b><br><span class="text-sm">完攀</span></div>
      <div style="text-align:center"><b style="font-size:22px;color:var(--red)">${targetClimbs.length-sends.length}</b><br><span class="text-sm">未完成</span></div>
    </div>
    <div class="goal-bar mt-16"><div class="fill" style="width:${targetClimbs.length>0?Math.round(sends.length/targetClimbs.length*100):0}%;background:var(--green)"></div></div>
    <div class="text-sm text-center mt-8">
      ${sends.length>0 ? `完成率 ${Math.round(sends.length/targetClimbs.length*100)}%，继续加油！` : targetClimbs.length>0 ? '还没有完成过，继续努力！' : '还没尝试过这个难度，去试试吧！'}
    </div>
  `;
}

// ── 目标模态框 ──
function showGoalModal() {
  document.getElementById('goalModal').classList.add('show');
  const goal = getGoal();
  if (goal) {
    document.getElementById('goalType').value = goal.type;
    if(goal.type==='count') document.getElementById('goalCount').value = goal.target;
    if(goal.type==='grade' && goal.target) document.getElementById('goalGrade').value = goal.target;
  }
  document.getElementById('goalGrade').innerHTML = GRADES.map(g=>`<option value="${g}">${g}</option>`).join('');
  document.getElementById('goalType').dispatchEvent(new Event('change'));
}
function closeGoalModal() { document.getElementById('goalModal').classList.remove('show'); }
document.getElementById('goalType').addEventListener('change', function() {
  document.getElementById('goalCountRow').style.display = this.value==='count'?'block':'none';
  document.getElementById('goalGradeRow').style.display = this.value==='count'?'none':'block';
});
function saveGoal() {
  const type = document.getElementById('goalType').value;
  const target = type==='count' ? parseInt(document.getElementById('goalCount').value) : document.getElementById('goalGrade').value;
  save('goal',{type,target});
  closeGoalModal();
  renderGoals();
}

// ── 提醒 ──
function toggleReminder(on) {
  save('remind', on);
  if (on) {
    // 顺便尝试请求浏览器原生通知权限（非必须，锦上添花）
    if (hasNotify() && Notification.permission === 'default') {
      Notification.requestPermission();
    }
  }
  renderGoals();
}

function checkReminder() {
  var remind = load('remind');
  if (!remind) return;

  var now = new Date();
  var todayStr = now.toISOString().split('T')[0];
  var banner = document.getElementById('reminderBanner');
  var textEl = document.getElementById('reminderBannerText');
  if (!banner || !textEl) return;

  var isUrgent = false;
  var msg = '';

  // 先检查自选训练日期
  var trainDates = getTrainDates();
  if (trainDates.indexOf(todayStr) !== -1) {
    var wd = ['日','一','二','三','四','五','六'][now.getDay()];
    msg = '🏋️ 今天是 ' + (now.getMonth()+1) + '月' + now.getDate() + '日 周' + wd + '，训练日！该去攀岩了';
    isUrgent = true;
  } else {
    // 再检查目标进度
    var goal = getGoal();
    if (goal && goal.type === 'count') {
      var climbs = getClimbs();
      var monthStart = new Date(now.getFullYear(), now.getMonth(), 1);
      var done = climbs.filter(function(c) { return new Date(c.date) >= monthStart; }).length;
      var remaining = goal.target - done;
      if (remaining > 0) {
        var lastDay = new Date(now.getFullYear(), now.getMonth()+1, 0).getDate();
        var daysRemain = lastDay - now.getDate();
        if (daysRemain > 0) {
          msg = '📊 本月还差 ' + remaining + ' 次训练，剩 ' + daysRemain + ' 天，日均需 ' + Math.ceil(remaining/daysRemain) + ' 次';
          isUrgent = true;
        }
      }
    }
  }

  if (isUrgent) {
    banner.style.display = 'flex';
    banner.style.background = 'var(--accent)';
    banner.style.color = '#fff';
    textEl.textContent = msg;
  } else {
    banner.style.display = 'none';
  }
}

// ── 攻克难度模态框 ──
function showTargetModal() {
  document.getElementById('targetModal').classList.add('show');
  document.getElementById('targetGrade').innerHTML = GRADES.map(g=>`<option value="${g}">${g}</option>`).join('');
  const t = getTarget();
  if(t) document.getElementById('targetGrade').value = t.grade;
}
function closeTargetModal() { document.getElementById('targetModal').classList.remove('show'); }
function saveTarget() {
  save('target', { grade: document.getElementById('targetGrade').value });
  closeTargetModal();
  renderGoals();
}

// ── 导航 ──
function switchView(viewId) {
  document.querySelectorAll('.view').forEach(v=>v.classList.remove('active'));
  document.querySelectorAll('nav button').forEach(b=>b.classList.remove('active'));
  document.getElementById(viewId).classList.add('active');
  document.querySelector(`nav button[data-view="${viewId}"]`).classList.add('active');
  if(viewId==='homeView') renderHome();
  if(viewId==='historyView') renderHistory();
  if(viewId==='goalsView') renderGoals();
}

// 模态框关闭
document.getElementById('goalModal').addEventListener('click',function(e){if(e.target===this)closeGoalModal();});
document.getElementById('targetModal').addEventListener('click',function(e){if(e.target===this)closeTargetModal();});

init();
</script>
