  climbs.push({ id: Date.now(), date: ts, zone: selZone, grade: selGrade, style: selStyle, result: selResult, duration: durVal });
  save('climbs', climbs);

  selGrade = selStyle = selResult = null;
  document.querySelectorAll('#gradeGrid .sel, #styleTags .sel, #resultTags .sel').forEach(e=>e.classList.remove('sel'));
  document.getElementById('saveBtn').disabled = true;

  // Reset zone back to boulder
  selZone = 'boulder';
  document.querySelectorAll('.zone-btn').forEach(function(b){b.classList.remove('sel');});
  var boulderBtn = document.querySelector('.zone-btn[data-zone="boulder"]');
