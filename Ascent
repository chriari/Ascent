// ── 难度进度条 + 统计卡片 ──
const GRADE_COLORS = ['#5ee4d0','#48cec4','#4eaee0','#5b8df0','#7c8cf8','#8d7ef0','#9e70e8','#af62e0','#bd5ad8','#c960d0','#c07ef0'];

function statCard(title, climbs, chartType) {
  const total = climbs.length;
  const sends = climbs.filter(c=>c.result!=='project');
  const best = sends.length>0 ? sends.reduce((a,b)=>GRADES.indexOf(a.grade)>GRADES.indexOf(b.grade)?a:b).grade : '-';

  // ── 难度分布 ──
  const gMap = {};
  climbs.forEach(c=>{ gMap[c.grade]=(gMap[c.grade]||0)+1; });
  const gList = GRADES.filter(g=>gMap[g]).map((g,i)=>{
    const idx = GRADES.indexOf(g);
    return {label:g, count:gMap[g], color:GRADE_COLORS[Math.min(idx,GRADE_COLORS.length-1)]};
  });
  const gMax = Math.max(...gList.map(g=>g.count), 1);

  let gSection = '';
  if (chartType==='pie') {
    // SVG 饼图
    let cumAngle = 0, paths = '';
    gList.forEach(d => {
      if(d.count===0) return;
      const angle = d.count/total * 360;
      const sr = (cumAngle - 90) * Math.PI / 180;
      const er = (cumAngle + angle - 90) * Math.PI / 180;
      const x1 = 60 + 50 * Math.cos(sr), y1 = 60 + 50 * Math.sin(sr);
      const x2 = 60 + 50 * Math.cos(er), y2 = 60 + 50 * Math.sin(er);
      const la = (angle > 180) ? 1 : 0;
      paths += `<path d="M60 60 L${x1} ${y1} A50 50 0 ${la} 1 ${x2} ${y2} Z" fill="${d.color}" stroke="var(--bg)" stroke-width="1"/>`;
      cumAngle += angle;
    });
    gSection = `<div style="text-align:center">${paths?`<svg viewBox="0 0 120 120" width="140" height="140">${paths}</svg>`:''}</div>`;
    // 图例
    gSection += '<div style="display:flex;flex-wrap:wrap;gap:2px 12px;justify-content:center;margin-top:4px">';
    gList.forEach(d => {
      gSection += `<span style="font-size:11px"><span style="display:inline-block;width:8px;height:8px;border-radius:2px;background:${d.color};vertical-align:middle;margin-right:3px"></span>${d.label} <b style="color:var(--accent)">${d.count}</b></span>`;
    });
    gSection += '</div>';
  } else {
    // 水平进度条
    gSection = '';
    gList.forEach(g=>{
      const pct = Math.round(g.count/gMax*100);
      gSection += `<div style="display:flex;align-items:center;gap:8px;margin-bottom:4px">
        <span style="font-size:12px;font-weight:700;min-width:28px;color:${g.color}">${g.label}</span>
        <div style="flex:1;height:14px;background:var(--border);border-radius:4px;overflow:hidden">
          <div style="width:${pct}%;height:100%;background:${g.color};border-radius:4px;transition:width .3s"></div>
        </div>
        <span style="font-size:12px;min-width:24px;text-align:right;color:var(--accent);font-weight:700">${g.count}次</span>
      </div>`;
    });
  }

  // ── 风格统计 ──
  const sMap = {};
  climbs.forEach(c=>{
    const styles = ZONE_STYLES[c.zone]||ZONE_STYLES.boulder;
    const sl = styles.find(s=>s.key===c.style)?.label||c.style;
    sMap[sl]=(sMap[sl]||0)+1;
  });
  const sList = Object.entries(sMap).sort((a,b)=>b[1]-a[1]);
  let shtml = '';
  sList.forEach(([k,v])=>{
    shtml += `<span style="background:var(--border);padding:2px 8px;border-radius:10px;font-size:11px;margin:0 3px 4px 0;display:inline-block">${k} <b style="color:var(--accent)">${v}</b></span>`;
  });

  // ── 结果统计 ──
  const rMap = {};
  climbs.forEach(c=>{ rMap[c.result]=(rMap[c.result]||0)+1; });
  const rColors = {send:'#5b9bd5',project:'#7c6ff7'};
  const rLabels = {send:'完攀',project:'攻克中'};

  return `<div class="card">
    <h3>${title}</h3>
    <div style="text-align:center;margin:4px 0">
      <span style="font-size:36px;font-weight:900;color:var(--accent)">${total}</span>
      <span style="font-size:16px;color:var(--text2)"> 次</span>
    </div>
    <div style="display:flex;gap:12px;justify-content:center;font-size:13px;margin-bottom:8px">
      <span>完攀 <b style="color:var(--green)">${sends.length}</b></span>
      <span>最高 <b>${best}</b></span>
      <span>成功率 <b>${total>0?Math.round(sends.length/total*100):0}%</b></span>
    </div>
    <div style="font-size:11px;color:var(--text2);margin-bottom:4px">难度分布</div>
    ${gSection}
    <div style="margin-top:10px;font-size:11px;color:var(--text2);margin-bottom:4px">线路风格</div>
    <div style="line-height:1.8">${shtml||'<span style="color:var(--text2);font-size:12px">-</span>'}</div>
    <div style="margin-top:8px;font-size:11px;color:var(--text2);margin-bottom:2px">攀爬结果</div>
    <div style="font-size:13px">
      ${RESULTS.filter(r=>rMap[r.key]).map(r=>`<span style="color:${rColors[r.key]};font-weight:700">${rLabels[r.key]} ${rMap[r.key]||0}</span>`).join(' <span style="color:var(--border)">|</span> ') || '<span style="color:var(--text2);font-size:12px">-</span>'}
    </div>
  </div>`;
}

