let swipeOpen = null; // currently open swipe item
let swipeStartX = 0, swipeStartY = 0, swipeEl = null, swipeOffset = 0;

function climbItemHTML(c) {
  const zoneLabel = c.zone==='rope'?'绳攀':'抱石';
  const styles = ZONE_STYLES[c.zone]||ZONE_STYLES.boulder;
  const sl = styles.find(s=>s.key===c.style)?.label||c.style;
