<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>Ascent</title>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --bg: #0d1117; --card: #161b24; --border: #21262d; --text: #e4e8f0;
    --text2: #69718b; --accent: #7c8cf8; --green: #4ade80;
    --red: #f87171; --blue: #5b9bd5; --radius: 12px;
  }
  body {
    font-family: -apple-system, BlinkMacSystemFont, 'SF Pro', sans-serif;
    background: var(--bg); color: var(--text); min-height: 100dvh;
    padding-bottom: 72px; -webkit-tap-highlight-color: transparent;
    -webkit-font-smoothing: antialiased;
  }
  header {
    padding: 18px 20px; display: flex; justify-content: space-between;
    align-items: center; position: sticky; top: 0; background: var(--bg); z-index: 10;
    backdrop-filter: blur(12px);
  }
  header h1 { font-size: 20px; font-weight: 700; letter-spacing: -.3px; }
  .btn {
    border: none; border-radius: 8px; padding: 10px 18px;
    font-size: 15px; font-weight: 600; cursor: pointer; transition: all .15s;
  }
  .btn:active { opacity: .7; transform: scale(.97); }
  .btn-accent { background: var(--accent); color: #fff; }
  .btn-accent:active { background: #6b7aee; }
  .btn-outline { background: transparent; border: 1px solid var(--border); color: var(--text); }

  /* Grade grid */
  .grade-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; padding: 0 16px; }
  .grade-btn {
    background: var(--card); border: 1.5px solid transparent; border-radius: var(--radius);
    padding: 14px 8px; color: var(--text); font-size: 16px; font-weight: 700;
    cursor: pointer; text-align: center; transition: all .15s;
  }
  .grade-btn:active { transform: scale(.95); }
  .grade-btn.sel { border-color: var(--accent); background: rgba(124,140,248,.12); }

  /* Tag chips */
  .tag-row { display: flex; flex-wrap: wrap; gap: 8px; padding: 0 16px; }
  .tag {
    background: var(--card); border: 1.5px solid transparent; border-radius: 20px;
    padding: 10px 16px; color: var(--text); font-size: 14px; font-weight: 600;
    cursor: pointer; transition: all .15s;
  }
  .tag:active { transform: scale(.95); }
  .tag.sel { border-color: var(--accent); background: rgba(124,140,248,.12); }

  /* Zone toggle */
  .zone-toggle { display: flex; gap: 8px; padding: 0 16px; }
  .zone-btn {
    flex: 1; background: var(--card); border: 1.5px solid transparent; border-radius: var(--radius);
    padding: 12px; color: var(--text); font-size: 15px; font-weight: 600;
    cursor: pointer; text-align: center; transition: all .15s;
  }
  .zone-btn:active { transform: scale(.95); }
  .zone-btn.sel { border-color: var(--accent); background: rgba(124,140,248,.12); }
  .zone-btn .sub { font-size: 11px; color: var(--text2); display: block; margin-top: 2px; }

  /* Cards */
  .card { background: var(--card); border-radius: var(--radius); padding: 16px; margin: 8px 16px; }
  .card h3 { font-size: 13px; color: var(--text2); margin-bottom: 8px; letter-spacing: .5px; }

  /* Stats */
  .stat-row { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; padding: 0 16px; margin: 12px 0; }
  .stat { background: var(--card); border-radius: var(--radius); padding: 16px 10px; text-align: center; }
  .stat .num { font-size: 28px; font-weight: 800; color: var(--accent); }
  .stat .label { font-size: 11px; color: var(--text2); margin-top: 4px; }

  /* Calendar */
  .cal-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 4px; margin-bottom: 10px;
  }
  .cal-header .month-label { font-size: 15px; font-weight: 700; }
  .cal-nav {
    background: none; border: none; color: var(--text2); font-size: 16px;
    cursor: pointer; padding: 4px 10px; border-radius: 6px; transition: all .15s;
  }
  .cal-nav:active { background: var(--border); color: var(--text); }
  .cal-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 4px; text-align: center; }
  .cal-grid .day-head { font-size: 10px; color: var(--text2); padding: 4px 0 6px; }
  .cal-grid .day {
    aspect-ratio: 1; display: flex; align-items: center; justify-content: center;
    border-radius: 50%; font-size: 13px; font-weight: 600;
  }
  .cal-grid .day.today { box-shadow: inset 0 0 0 2px var(--accent); }
  .cal-grid .day.has-climb { background: var(--accent); color: #fff; }
  .cal-grid .day.muted { color: #2d3140; }

  /* Climb item */
  .climb-item {
    display: flex; align-items: center; gap: 10px; padding: 10px 0;
    border-bottom: 1px solid var(--border); font-size: 15px;
  }
  .climb-item:last-child { border-bottom: none; }
  .grade-badge {
    background: var(--accent); color: #fff; border-radius: 6px;
    padding: 4px 8px; font-size: 13px; font-weight: 700; min-width: 36px; text-align: center;
  }
  .grade-badge.send { background: var(--blue); }
  .grade-badge.project { background: #7c6ff7; }
  .zone-badge {
    font-size: 11px; color: var(--text2); border: 1px solid var(--border);
    border-radius: 4px; padding: 1px 5px; margin-left: 4px;
  }

  /* Bottom nav */
  nav {
    position: fixed; bottom: 0; left: 0; right: 0; background: rgba(22,27,36,.92);
    display: flex; border-top: 1px solid var(--border); z-index: 10;
    backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
  }
  nav button {
    flex: 1; background: none; border: none; color: var(--text2);
    padding: 8px 6px 8px; font-size: 11px; cursor: pointer; transition: color .2s;
  }
  nav button.active { color: var(--accent); }
  nav button .nav-icon { font-size: 20px; display: block; margin-bottom: 2px; }

  /* Views */
  .view { display: none; padding: 0 0 20px; }
  .view.active { display: block; }

  /* Goal bar */
  .goal-bar { height: 8px; background: var(--border); border-radius: 4px; margin-top: 8px; overflow: hidden; }
  .goal-bar .fill { height: 100%; background: var(--accent); border-radius: 4px; transition: width .3s; }

  /* Big progress */
  .big-progress { text-align: center; padding: 8px 0 4px; }
  .big-progress .done { font-size: 48px; font-weight: 900; color: var(--accent); }
  .big-progress .sep { font-size: 24px; color: var(--text2); margin: 0 4px; }
  .big-progress .target { font-size: 24px; color: var(--text2); font-weight: 700; }
  .big-progress .unit { font-size: 14px; color: var(--text2); margin-left: 2px; }

  .btn-full { width: calc(100% - 32px); margin: 0 16px; padding: 14px; font-size: 16px; }

  .meta-row { display: flex; gap: 8px; padding: 0 16px; }
  .meta-row .input {
    flex: 1; background: var(--card); border: 1px solid var(--border); border-radius: var(--radius);
    padding: 12px; color: var(--text); font-size: 15px;
  }
  .meta-row .input[type="date"] { color-scheme: dark; }

  /* History tabs */
  .history-tabs { display: flex; gap: 4px; padding: 0 16px; margin-bottom: 12px; }
  .history-tab {
    flex: 1; background: var(--card); border: 1.5px solid transparent; border-radius: 20px;
    padding: 8px; color: var(--text2); font-size: 13px; font-weight: 600;
    cursor: pointer; text-align: center; transition: all .15s;
  }
  .history-tab.sel { border-color: var(--accent); color: var(--accent); background: rgba(124,140,248,.08); }

  .text-center { text-align: center; }
  .mt-8 { margin-top: 8px; }
  .mt-16 { margin-top: 16px; }
  .mb-8 { margin-bottom: 8px; }
  .text-sm { font-size: 13px; color: var(--text2); }

  /* Modal */
  .modal-overlay {
    display: none; position: fixed; inset: 0; background: rgba(0,0,0,.7);
    z-index: 100; align-items: flex-end; justify-content: center;
  }
  .modal-overlay.show { display: flex; }
  .modal {
    background: var(--card); border-radius: 16px 16px 0 0; padding: 20px;
    width: 100%; max-height: 70dvh; overflow-y: auto;
  }
  .modal h2 { font-size: 18px; margin-bottom: 16px; }
  .input {
    width: 100%; background: var(--bg); border: 1px solid var(--border); border-radius: var(--radius);
    padding: 12px; color: var(--text); font-size: 15px;
  }
  .flex-between { display: flex; justify-content: space-between; align-items: center; }
  /* Swipe delete */
  .swipe-wrap { position: relative; overflow: hidden; margin: 0 -16px; }
  .swipe-bg {
    position: absolute; right: 0; top: 0; bottom: 0; width: 72px;
    background: var(--red); display: flex; align-items: center; justify-content: center;
    color: #fff; font-size: 14px; font-weight: 700; cursor: pointer;
  }
  .swipe-fg {
    position: relative; z-index: 1; background: var(--card); padding: 0 16px;
    transition: transform 0.25s ease;
  }
  .swipe-fg.open { transform: translateX(-72px); }
  .empty-state { text-align: center; padding: 40px 20px; color: var(--text2); }
  .empty-state .icon { font-size: 48px; margin-bottom: 12px; }

  /* Splash screen */
  .splash {
    position: fixed; inset: 0; z-index: 200; background: var(--bg);
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    transition: opacity .5s ease, visibility .5s ease;
  }
  .splash.hide { opacity: 0; visibility: hidden; pointer-events: none; }
  .splash h2 {
    font-size: 26px; font-weight: 800; text-align: center; padding: 0 32px;
    color: var(--text); line-height: 1.5; letter-spacing: -.3px;
  }
  .splash h2 span { color: var(--accent); }
  .splash .sub { font-size: 14px; color: var(--text2); margin-top: 8px; }
  .splash .btn-enter {
    margin-top: 40px; padding: 14px 36px; font-size: 16px;
    background: linear-gradient(135deg, var(--accent), #9b8cf8);
    color: #fff; border: none; border-radius: 12px; font-weight: 700;
    cursor: pointer; transition: all .2s; letter-spacing: .5px;
  }
  .splash .btn-enter:active { transform: scale(.96); opacity: .85; }

  /* Big grade display */
  .big-grade {
    font-size: 48px; font-weight: 900; text-align: center; padding: 16px 0;
    color: var(--accent);
  }
</style>
</head>
<body>

<div class="splash" id="splash">
  <h2>Welcome to<br><span>Ascent</span></h2>
  <div class="sub">私人攀岩进度管理</div>
  <button class="btn-enter" onclick="dismissSplash()">进入</button>
</div>

<header>
  <h1>🧗 Ascent</h1>
  <span id="headerDate" style="font-size:14px;color:var(--text2)"></span>
</header>
<div id="reminderBanner" style="display:none;margin:0 16px 8px;padding:12px 16px;border-radius:10px;font-size:14px;font-weight:700;align-items:center;justify-content:space-between;gap:8px">
  <span id="reminderBannerText"></span>
  <span onclick="document.getElementById('reminderBanner').style.display='none'" style="cursor:pointer;font-size:18px;opacity:0.6;flex-shrink:0">&times;</span>
</div>

<!-- ====== 总览 ====== -->
<div id="homeView" class="view active">
  <div class="stat-row">
    <div class="stat"><div class="num" id="statTotal">0</div><div class="label">总攀爬</div></div>
    <div class="stat"><div class="num" id="statWeek">0</div><div class="label">本周攀爬</div></div>
    <div class="stat"><div class="num" id="statSends">0</div><div class="label">完攀记录</div></div>
    <div class="stat"><div class="num" id="statBest">-</div><div class="label">当前最高难度</div></div>
  </div>

  <div class="card" style="text-align:center;padding:12px 16px">
    <span style="color:var(--text2);font-size:13px">⏱ 累计训练时长</span>
    <span id="statDuration" style="font-size:20px;font-weight:800;margin-left:8px">0 分钟</span>
  </div>

  <div class="card">
    <div class="cal-header">
      <button class="cal-nav" onclick="calPrevMonth()">◀</button>
      <span class="month-label" id="calMonthLabel"></span>
      <button class="cal-nav" onclick="calNextMonth()">▶</button>
    </div>
    <div class="cal-grid" id="calDays"></div>
  </div>

  <div class="card">
    <h3>📋 今日 Session</h3>
    <div style="font-size:11px;color:var(--text2);margin-bottom:8px">← 左滑记录可删除</div>
    <div id="todayClimbs"><div class="empty-state"><div class="icon">🏔️</div>今天还没记录，快去爬吧！</div></div>
    <button class="btn btn-accent btn-full mt-16" onclick="switchView('logView')">+ 记录攀爬</button>
  </div>
</div>

<!-- ====== 记录 ====== -->
<div id="logView" class="view">
  <div class="card">
    <!-- Row 1: Date + Duration -->
    <div style="display:flex;gap:8px;padding:0;margin-bottom:4px">
      <span style="flex:1;font-size:12px;color:var(--text2)">日期 <span style="color:var(--red);font-size:10px">必选</span></span>
      <span style="flex:1;font-size:12px;color:var(--text2)">时长 <span style="color:var(--red);font-size:10px">必选</span></span>
    </div>
    <div class="meta-row" style="padding:0;margin-bottom:14px">
      <input type="date" id="logDate" class="input">
      <input type="number" id="logDuration" class="input" placeholder="时长(分钟)" min="0" step="5" inputmode="numeric">
    </div>
    <!-- Row 2: Zone -->
    <div class="zone-toggle" style="padding:0;margin-bottom:14px">
      <button class="zone-btn sel" data-zone="boulder" onclick="pickZone('boulder',this)">抱石<span class="sub">Bouldering</span></button>
      <button class="zone-btn" data-zone="rope" onclick="pickZone('rope',this)">绳攀<span class="sub">Rope</span></button>
    </div>
    <!-- Divider -->
    <div style="border-top:1px solid var(--border);margin-bottom:14px"></div>
    <!-- Row 3: Grade (required) -->
    <div style="font-size:12px;color:var(--text2);margin-bottom:6px">难度 <span style="color:var(--red);font-size:10px">必选</span></div>
    <div class="grade-grid" id="gradeGrid" style="padding:0;margin-bottom:14px"></div>
    <!-- Row 4: Style (required) -->
    <div style="font-size:12px;color:var(--text2);margin-bottom:6px">线路风格 <span style="color:var(--red);font-size:10px">必选</span></div>
    <div class="tag-row" id="styleTags" style="padding:0;margin-bottom:14px"></div>
    <!-- Row 5: Result (required) -->
    <div style="font-size:12px;color:var(--text2);margin-bottom:6px">结果 <span style="color:var(--red);font-size:10px">必选</span></div>
    <div class="tag-row" id="resultTags" style="padding:0;margin-bottom:14px"></div>
    <!-- Save -->
    <button class="btn btn-accent" style="width:100%;padding:14px;font-size:16px" id="saveBtn" disabled onclick="saveClimb()">记录攀爬</button>
    <div id="logFeedback" class="text-center mt-8" style="color:var(--green);display:none"></div>
  </div>
</div>

<!-- ====== 历史 ====== -->
<div id="historyView" class="view">
  <div class="history-tabs">
    <button class="history-tab sel" data-tab="day" onclick="switchHistoryTab('day',this)">按日</button>
    <button class="history-tab" data-tab="month" onclick="switchHistoryTab('month',this)">按月</button>
    <button class="history-tab" data-tab="year" onclick="switchHistoryTab('year',this)">按年</button>
  </div>
  <div style="padding:0 16px;margin-bottom:8px;font-size:11px;color:var(--text2)" id="swipeHint">← 左滑记录可删除</div>
  <div id="historyContent"></div>
</div>

<!-- ====== 目标 ====== -->
<div id="goalsView" class="view">
  <!-- 本月目标 -->
  <div class="card">
    <div class="flex-between">
      <h3 style="margin:0">🎯 本月目标</h3>
      <button class="btn btn-outline" style="padding:6px 12px;font-size:13px" onclick="showGoalModal()">设置</button>
    </div>
    <div id="goalContent"></div>
  </div>

  <!-- 训练日历 -->
  <div class="card">
    <h3 style="margin:0;margin-bottom:8px">📅 训练日历</h3>
    <div id="trainingCalendarContent"></div>
  </div>

  <!-- 目标攻克难度 -->
  <div class="card">
    <div class="flex-between">
      <h3 style="margin:0">💪 目标攻克难度</h3>
      <button class="btn btn-outline" style="padding:6px 12px;font-size:13px" onclick="showTargetModal()">设置</button>
    </div>
    <div id="targetContent"></div>
  </div>

  <!-- 训练提醒 -->
  <div class="card">
    <h3 style="margin:0;margin-bottom:8px">🔔 训练提醒</h3>
    <div id="reminderContent"></div>
  </div>
</div>

<!-- ====== 底部导航 ====== -->
<nav>
  <button class="active" data-view="homeView" onclick="switchView('homeView')">
    <span class="nav-icon">📊</span>总览
  </button>
  <button data-view="goalsView" onclick="switchView('goalsView')">
    <span class="nav-icon">🎯</span>目标
  </button>
  <button data-view="logView" onclick="switchView('logView')">
    <span class="nav-icon">➕</span>记录
  </button>
  <button data-view="historyView" onclick="switchView('historyView')">
    <span class="nav-icon">📅</span>历史
  </button>
</nav>

<!-- ====== 目标模态框 ====== -->
<div class="modal-overlay" id="goalModal">
  <div class="modal">
    <h2>设置本月目标</h2>
    <div style="margin-bottom:12px">
      <label class="text-sm">目标类型</label>
      <select id="goalType" class="input" style="margin-top:4px">
        <option value="count">本月攀爬次数</option>
        <option value="grade">完成指定难度</option>
      </select>
    </div>
    <div id="goalCountRow" style="margin-bottom:12px">
      <label class="text-sm">目标次数</label>
      <input id="goalCount" class="input" type="number" value="30" style="margin-top:4px">
    </div>
    <div id="goalGradeRow" style="margin-bottom:12px;display:none">
      <label class="text-sm">目标难度</label>
      <select id="goalGrade" class="input" style="margin-top:4px"></select>
    </div>
    <div style="display:flex;gap:8px">
      <button class="btn btn-accent" style="flex:1" onclick="saveGoal()">保存</button>
      <button class="btn btn-outline" style="flex:1" onclick="closeGoalModal()">取消</button>
    </div>
  </div>
</div>

<!-- ====== 攻克难度模态框 ====== -->
<div class="modal-overlay" id="targetModal">
  <div class="modal">
    <h2>设置目标攻克难度</h2>
    <div style="margin-bottom:12px">
      <label class="text-sm">想要攻克的难度</label>
      <select id="targetGrade" class="input" style="margin-top:4px"></select>
    </div>
    <div style="display:flex;gap:8px">
      <button class="btn btn-accent" style="flex:1" onclick="saveTarget()">保存</button>
      <button class="btn btn-outline" style="flex:1" onclick="closeTargetModal()">取消</button>
    </div>
  </div>
</div>

<script>
// ── 数据层 ──
const GRADES = ['V0','V1','V2','V3','V4','V5','V6','V7','V8','V9','V10'];

const ZONE_STYLES = {
  boulder: [
    {key:'slab',label:'俯角板'},{key:'vert',label:'垂直面'},{key:'overhang',label:'仰角'},
    {key:'steep',label:'大角度'},{key:'roof',label:'屋檐'},{key:'crimp',label:'指力点'},
    {key:'sloper',label:'摩擦点'},{key:'pinch',label:'捏点'},{key:'dyno',label:'动态线'},
    {key:'comp',label:'压缩线'},{key:'crack',label:'裂缝'},
  ],
  rope: [
    {key:'slab',label:'俯角'},{key:'vert',label:'垂直'},{key:'overhang',label:'仰角'},
    {key:'steep',label:'大仰角'},{key:'roof',label:'屋檐'},{key:'crack',label:'裂缝'},
    {key:'tufa',label:'钟乳'},{key:'tech',label:'技术型'},{key:'endurance',label:'耐力型'},
    {key:'balance',label:'平衡型'},
  ],
};

const RESULTS = [
  {key:'send',label:'✅ 完攀',cls:'send'},
  {key:'project',label:'🔴 攻克中',cls:'project'},
];

function load(k) { return JSON.parse(localStorage.getItem('cc_'+k) || 'null'); }
function save(k,v) { localStorage.setItem('cc_'+k, JSON.stringify(v)); }
function getClimbs() { return load('climbs') || []; }
function getGoal() { return load('goal') || null; }
function getTarget() { return load('target') || null; }

// ── 状态 ──
let selZone = 'boulder', selGrade = null, selStyle = null, selResult = null;
let calYear, calMonth, historyTab = 'day';

// ── 开屏 ──
function dismissSplash() {
  var splash = document.getElementById('splash');
  splash.classList.add('hide');
}

// ── 初始化 ──
function init() {
  // 开屏：每次访问都显示
  document.getElementById('splash').classList.remove('hide');

  document.getElementById('headerDate').textContent = new Date().toLocaleDateString('zh-CN',{month:'long',day:'numeric',weekday:'short'});
  const now = new Date();
  calYear = now.getFullYear(); calMonth = now.getMonth();
  document.getElementById('logDate').value = now.toISOString().split('T')[0];
  renderGradeGrid(); renderStyleTags(); renderResultTags();
  renderHome(); renderHistory(); renderGoals();
  setTimeout(checkReminder, 2000);
}

function renderGradeGrid() {
  document.getElementById('gradeGrid').innerHTML = GRADES.map(v =>
    `<button class="grade-btn" data-grade="${v}" onclick="pickGrade('${v}',this)">${v}</button>`).join('');
}
function renderStyleTags() {
  document.getElementById('styleTags').innerHTML = ZONE_STYLES[selZone].map(s =>
    `<span class="tag" data-style="${s.key}" onclick="pickStyle('${s.key}',this)">${s.label}</span>`).join('');
}
function renderResultTags() {
  document.getElementById('resultTags').innerHTML = RESULTS.map(r =>
    `<span class="tag" data-result="${r.key}" onclick="pickResult('${r.key}',this)">${r.label}</span>`).join('');
}

// ── 选择逻辑 ──
